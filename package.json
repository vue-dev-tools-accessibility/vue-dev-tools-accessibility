{
  "name": "vue-dev-tools-accessibility",
  "version": "0.5.3",
  "type": "module",
  "main": "index.js",
  "exports": {
    ".": {
      "import": "./index.js",
      "require": "./index.cjs"
    }
  },
  "scripts": {
    "build": "vite build",
    "build-dev": "cross-env VITE_A11Y=local npm run build",
    "postbuild-dev": "node ./scripts/postbuild-dev.js",
    "prepublishOnly": "npm run build",
    "test": "cross-env TZ=America/New_York vitest run --coverage",
    "unit": "cross-env TZ=America/New_York vitest --coverage",
    "lint": "eslint --ext .js,.vue src tests vite.config.js eslint.config.js",
    "fix": "npm run lint -- --fix",
    "bump": "npx --yes -- @jsdevtools/version-bump-prompt && npm i",
    "volta": "volta pin node@latest && volta pin npm@latest && git status",
    "outdated": "npm outdated"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@vitest/coverage-v8": "^4.0.14",
    "@vue/devtools-api": "^8.0.5",
    "apca-check": "^0.1.1",
    "axe-core": "^4.11.0",
    "cross-env": "^10.1.0",
    "eslint": "^10.6.0",
    "eslint-config-tjw-base": "^5.0.0",
    "eslint-config-tjw-import-x": "^1.0.1",
    "eslint-config-tjw-jest": "^4.0.0",
    "eslint-import-resolver-vite": "^2.2.0",
    "eslint-plugin-import-x": "^4.17.1",
    "eslint-plugin-jest": "^29.15.4",
    "globals": "^17.7.0",
    "happy-dom": "^20.0.11",
    "lodash-es": "^4.17.21",
    "vite": "^7.2.6",
    "vitest": "^4.0.14"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "26.4.0"
    },
    "packageManager": {
      "name": "npm",
      "version": "11.17.0"
    }
  }
}
